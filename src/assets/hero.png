function StatsCards({ items = stats }) {
  return (
    <section className="stats-grid">
      {items.map((stat) => {
        const Icon = typeof stat.icon === "string" ? apiIconMap[stat.icon] || Activity : stat.icon;
        return (
          <div className="card" key={stat.title}>
            <div className="stat-card">
              <div>
                <p className="muted">{stat.title}</p>
                <h3 className="stat-value">{stat.value}</h3>
                <p className="small-muted">{stat.sub}</p>
              </div>
              <div className="stat-icon">
                <Icon size={20} />
              </div>
            </div>
          </div>
        );
      })}
    </section>
  );
}

function DashboardPage() {
  const [dashboard, setDashboard] = useState(fallbackDashboard);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");

  useEffect(() => {
    const loadDashboard = async () => {
      try {
        const response = await fetch("/api/dashboard");
        if (!response.ok) {
          throw new Error(`Dashboard request failed (${response.status})`);
        }
        const data = await response.json();
        setDashboard({
          stats: data.stats || fallbackDashboard.stats,
          recentPredictions: data.recentPredictions || [],
          distributionData: data.distributionData || [],
          trendData: data.trendData || [],
          monthlyConfidence: data.monthlyConfidence || [],
        });
      } catch (err) {
        console.error(err);
        setError("Backend data could not be loaded, so fallback demo data is shown.");
      } finally {
        setLoading(false);
      }
    };

    loadDashboard();
  }, []);

  return (
    <div className="page-section">
      {error ? <div className="empty-box" style={{ color: "#b91c1c" }}>{error}</div> : null}
      {loading ? <div className="empty-box">Loading database dashboard...</div> : null}
      <StatsCards items={dashboard.stats} />

      <section className="grid-two">
        <div className="card">
          <div className="card-header">
            <h3>Weekly Analysis Volume</h3>
            <p>Number of analyzed articles over the last 7 days.</p>
          </div>
          <div className="card-body chart-box">
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={dashboard.trendData}>
                <CartesianGrid vertical={false} strokeDasharray="3 3" />
                <XAxis dataKey="day" />
                <YAxis />
                <Tooltip content={<CustomTooltip />} />
                <Bar dataKey="count" name="Articles" fill="#0f172a" radius={[12, 12, 0, 0]} />
              </BarChart>
            </ResponsiveContainer>
          </div>
        </div>

        <div className="card">
          <div className="card-header">
            <h3>Class Distribution</h3>
            <p>Prediction classes from recent analysis sessions.</p>
          </div>
          <div className="card-body chart-box">
            <ResponsiveContainer width="100%" height="100%">
              <PieChart>
                <Pie data={dashboard.distributionData} dataKey="value" nameKey="name" innerRadius={70} outerRadius={110} paddingAngle={3}>
                  {dashboard.distributionData.map((entry, index) => (
                    <Cell key={entry.name} fill={chartPalette[index % chartPalette.length]} />
                  ))}
                </Pie>
                <Tooltip content={<CustomTooltip suffix="%" />} />
              </PieChart>
            </ResponsiveContainer>
          </div>
          <div className="mini-grid">
            {dashboard.distributionData.map((item) => (
              <div key={item.name} className="mini-card">
                <span>{item.name}</span>
                <strong>{formatPercent(item.value)}</strong>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section className="grid-two">
        <div className="card">
          <div className="card-header">
            <h3>Model Confidence Trend</h3>
            <p>Average confidence progression by month.</p>
          </div>
          <div className="card-body chart-box">
            <ResponsiveContainer width="100%" height="100%">
              <LineChart data={dashboard.monthlyConfidence}>
                <CartesianGrid vertical={false} strokeDasharray="3 3" />
                <XAxis dataKey="month" />
                <YAxis domain={[70, 100]} />
                <Tooltip content={<CustomTooltip suffix="%" />} />
                <Line type="monotone" dataKey="value" name="Confidence" stroke="#0f172a" strokeWidth={3} dot={{ r: 4 }} />
              </LineChart>
            </ResponsiveContainer>
          </div>
        </div>

        <div className="card">
          <div className="card-header">
            <h3>Recent Predictions</h3>
            <p>Live stream of the latest classified articles.</p>
          </div>
          <div className="card-body stack-gap">
            {dashboard.recentPredictions.map((item) => (
              <div key={item.id} className="list-card">
                <div>
                  <p className="item-title">{item.title}</p>
                  <div className="item-meta">
                    <span>{item.source}</span>
                    <span>•</span>
                    <span>{item.time}</span>
                  </div>
                </div>
                <div className="text-right">
                  <LabelBadge label={item.label} />
                  <p className="small-strong">{formatPercent(item.confidence)}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </div>
  );
}

function AnalyzePage() {
  const [headline, setHeadline] = useState("");
  const [sourceUrl, setSourceUrl] = useState("");
  const [articleText, setArticleText] = useState("");
  const [modelVersion, setModelVersion] = useState("Python Multinomial Naive Bayes v1.0");
  const [language, setLanguage] = useState("English");
  const [saveResult, setSaveResult] = useState(true);
  const [prediction, setPrediction] = useState(initialPrediction);
  const [loading, setLoading] = useState(false);
  const [fetchingUrl, setFetchingUrl] = useState(false);
  const [error, setError] = useState("");

  useEffect(() => {
    const loadExample = async () => {
      try {
        const response = await fetch("/api/articles?label=Real&limit=1");
        if (!response.ok) return;
        const data = await response.json();
        const article = data.articles?.[0];
        if (!article) return;
        setHeadline(article.title);
        setSourceUrl("");
        setArticleText(article.preview);
      } catch (err) {
        console.error(err);
      }
    };

    loadExample();
  }, []);

  const fetchFromUrl = async () => {
    if (!sourceUrl.trim().startsWith("http")) {
      setError("Vendos nje link valid qe fillon me http ose https.");
      return;
    }

    setFetchingUrl(true);
    setError("");

    try {
      const response = await fetch("/api/fetch-url", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ url: sourceUrl }),
      });

      if (!response.ok) {
        const errorData = await response.json().catch(() => ({}));
        throw new Error(errorData.message || `URL fetch failed with status ${response.status}`);
      }

      const data = await response.json();
      setHeadline(data.title || headline);
      setArticleText(data.text || "");
      setError(data.warning || "");
    } catch (err) {
      console.error(err);
      setError(err.message || "Nuk munda ta lexoj lajmin nga ky link. Provo nje link tjeter ose ngjite tekstin manualisht.");
    } finally {
      setFetchingUrl(false);
    }
  };

  const runAnalysis = async () => {
    setLoading(true);
    setError("");

    try {
      const response = await fetch("/api/analyze", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          headline,
          source: sourceUrl,
          url: sourceUrl,
          text: articleText,
          model: modelVersion,
          language,
          save: saveResult,
        }),
      });

      if (!response.ok) {
        const errorData = await response.json().catch(() => ({}));
        throw new Error(errorData.message || `Request failed with status ${response.status}`);
      }

      const data = await response.json();
      setPrediction({
        label: data.label,
        confidence: data.confidence,
        processed: true,
        explanation: data.explanation || "The classifier returned a result.",
        probabilities: data.probabilities || {},
        topEvidence: data.topEvidence || [],
        modelName: data.modelName || modelVersion,
      });
      if (data.headline) setHeadline(data.headline);
      if (data.text) setArticleText(data.text);
    } catch (err) {
      console.error(err);
      setError(err.message || "Nuk munda ta analizoj lajmin. Kontrollo backend-in ose provo tekst manual.");
    } finally {
      setLoading(false);
    }
  };

  const clearForm = () => {
    setPrediction(initialPrediction);
    setHeadline("");
    setSourceUrl("");
    setArticleText("");
  };

  const getScore = (label) => Math.round(prediction.probabilities?.[label] || (prediction.label === label ? prediction.confidence : 0));

  return (
    <div className="grid-two analyze-grid">
      <div className="card">
        <div className="card-header">
          <h3>Analyze News Article</h3>
          <p>Paste a headline or full article text and run the classifier.</p>
        </div>
        <div className="card-body stack-gap">
          <div className="form-grid">
            <div>
              <label className="field-label">Headline</label>
              <input
                className="input"
                value={headline}
                onChange={(event) => setHeadline(event.target.value)}
                placeholder="Enter news headline"
              />
            </div>
            <div>
              <label className="field-label">Source URL</label>
              <input
                className="input"
                value={sourceUrl}
                onChange={(event) => setSourceUrl(event.target.value)}
                placeholder="https://source.com/article"
              />
            </div>
          </div>

          <div>
            <label className="field-label">Article Text</label>
            <textarea
              className="textarea"
              value={articleText}
              onChange={(event) => setArticleText(event.target.value)}
            />
          </div>

          <div className="form-grid-three">
            <div>
              <label className="field-label">Model</label>
              <select className="input" value={modelVersion} onChange={(event) => setModelVersion(event.target.value)}>
                <option>Python Multinomial Naive Bayes v1.0</option>
                <option>Dataset Similarity + Keyword Rules v1.0</option>
                <option>Logistic Regression v2.1</option>
                <option>SVM v1.8</option>
                <option>Naive Bayes v1.4</option>
              </select>
            </div>
            <div>
              <label className="field-label">Language</label>
              <select className="input" value={language} onChange={(event) => setLanguage(event.target.value)}>
                <option>English</option>
                <option>Albanian</option>
                <option>Serbian</option>
              </select>
            </div>
            <div>
              <label className="field-label">Save Result</label>
              <div className="switch-row">
                <input type="checkbox" checked={saveResult} onChange={(event) => setSaveResult(event.target.checked)} />
                <span>Store in history</span>
              </div>
            </div>
          </div>

          {error ? <div className="empty-box" style={{ color: "#b91c1c" }}>{error}</div> : null}

          <div className="button-row">
            <button className="btn btn-light" disabled={fetchingUrl} onClick={fetchFromUrl} type="button">
              <Download size={16} />
              {fetchingUrl ? "Reading URL..." : "Fetch URL"}
            </button>
            <button className="btn btn-dark" disabled={loading} onClick={runAnalysis}>
              <Brain size={16} />
              {loading ? "Analyzing..." : "Run Naive Bayes"}
            </button>
            <button className="btn btn-light" onClick={clearForm} type="button">
              <RefreshCcw size={16} />
              Clear
            </button>
          </div>
        </div>
      </div>

      <div className="stack-gap">
        <div className="card">
          <div className="card-header">
            <h3>Prediction Result</h3>
            <p>Latest output from the text classification model.</p>
          </div>
          <div className="card-body">
            {prediction.processed ? (
              <div className="stack-gap">
                <div className="result-box">
                  <div>
                    <p className="muted">Predicted Class</p>
                    <div className="mt-8">
                      <LabelBadge label={prediction.label} />
                    </div>
                  </div>
                  <div className="text-right">
                    <p className="muted">Confidence</p>
                    <p className="big-number">{formatPercent(prediction.confidence)}</p>
                  </div>
                </div>

                <div className="stack-gap">
                  <div>
                    <div className="progress-label"><span>Fake</span><span>{getScore("Fake")}%</span></div>
                    <div className="progress"><div className="progress-fill" style={{ width: `${Math.max(getScore("Fake"), 4)}%` }} /></div>
                  </div>
                  <div>
                    <div className="progress-label"><span>Bias</span><span>{getScore("Bias")}%</span></div>
                    <div className="progress"><div className="progress-fill" style={{ width: `${Math.max(getScore("Bias"), 4)}%` }} /></div>
                  </div>
                  <div>
                    <div className="progress-label"><span>Satire</span><span>{getScore("Satire")}%</span></div>
                    <div className="progress"><div className="progress-fill" style={{ width: `${Math.max(getScore("Satire"), 4)}%` }} /></div>
                  </div>
                  <div>
                    <div className="progress-label"><span>Real</span><span>{getScore("Real")}%</span></div>
                    <div className="progress"><div className="progress-fill" style={{ width: `${Math.max(getScore("Real"), 4)}%` }} /></div>
                  </div>
                  <div>
                    <div className="progress-label"><span>Needs Review</span><span>{getScore("Needs Review")}%</span></div>
                    <div className="progress"><div className="progress-fill progress-fill-review" style={{ width: `${Math.max(getScore("Needs Review"), 4)}%` }} /></div>
                  </div>
                </div>

                <div className="separator" />

                {prediction.confidence < 70 ? (
                  <div className="warning-box">
                    Low confidence: review this result manually before making a final decision.
                  </div>
                ) : null}

                {prediction.topEvidence?.length ? (
                  <div className="evidence-list">
                    <p className="muted">Words that influenced prediction</p>
                    <div className="token-row">
                      {prediction.topEvidence.map((item) => (
                        <span key={item.token} className="token-pill">{item.token}</span>
                      ))}
                    </div>
                  </div>
                ) : null}

                <div className="grid-two small-grid">
                  <div className="mini-card left">
                    <p className="muted">Model Used</p>
                    <p className="small-strong">{prediction.modelName || modelVersion}</p>
                  </div>
                  <div className="mini-card left">
                    <p className="muted">Processing Time</p>
                    <p className="small-strong">{loading ? "Running..." : "0.84 sec"}</p>
                  </div>
                </div>
              </div>
            ) : (
              <div className="empty-box">Run analysis to see the result here.</div>
            )}
          </div>
        </div>

        <div className="card">
          <div className="card-header">
            <h3>Why this result?</h3>
            <p>Human-friendly explanation for the classification.</p>
          </div>
          <div className="card-body explanation">
            <p>{prediction.processed ? prediction.explanation : "The backend will provide a classification explanation after analysis."}</p>
          </div>
        </div>
      </div>
    </div>
  );
}

function HistoryPage() {
  const [query, setQuery] = useState("");
  const [rows, setRows] = useState(historyRows);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");

  useEffect(() => {
    const loadHistory = async () => {
      try {
        const response = await fetch("/api/history");
        if (!response.ok) {
          throw new Error(`Failed to load history (${response.status})`);
        }
        const data = await response.json();
        setRows(data.history || historyRows);
      } catch (err) {
        console.error(err);
        setError("Unable to fetch history. Confirm the backend is running on port 4000.");
      } finally {
        setLoading(false);
      }
    };

    loadHistory();
  }, []);

  const filtered = useMemo(() => filterHistoryRows(rows, query), [query, rows]);

  return (
    <div className="page-section">
      <div className="card">
        <div className="card-header">
          <h3>Analysis History</h3>
          <p>Search, filter, and review previously analyzed news items.</p>
        </div>
        <div className="card-body stack-gap">
          <div className="toolbar">
            <div className="toolbar-left">
              <div className="search-box wide">
                <Search size={16} />
                <input
                  value={query}
                  onChange={(e) => setQuery(e.target.value)}
                  type="text"
                  placeholder="Search by title, class, or source"
                />
              </div>
              <button className="btn btn-light">
                <Filter size={16} />
                Filters
              </button>
            </div>
            <div className="toolbar-right">
              <button className="btn btn-light">
                <Download size={16} />
                Export CSV
              </button>
              <button className="btn btn-dark">Generate Report</button>
            </div>
          </div>

          {loading ? (
            <div className="empty-box">Loading history...</div>
          ) : error ? (
            <div className="empty-box" style={{ color: "#b91c1c" }}>{error}</div>
          ) : (
            <div className="table-wrap">
              <table className="custom-table">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Source</th>
                    <th>Class</th>
                    <th>Confidence</th>
                    <th>Model</th>
                    <th>Date</th>
                  </tr>
                </thead>
                <tbody>
                  {filtered.map((row) => (
                    <tr key={row.id}>
                      <td>{row.id}</td>
                      <td>{row.title}</td>
                      <td>{row.source}</td>
                      <td><LabelBadge label={row.label} /></td>
                      <td>{formatPercent(row.confidence)}</td>
                      <td>{row.model}</td>
                      <td>{row.date}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

function MlLabPage() {
  const [report, setReport] = useState(null);
  const [loading, setLoading] = useState(true);
  const [training, setTraining] = useState(false);
  const [error, setError] = useState("");

  const loadReport = async () => {
    setError("");
    try {
      const response = await fetch("/api/model/report");
      if (!response.ok) {
        throw new Error(`Model report failed (${response.status})`);
      }
      const data = await response.json();
      setReport(data);
    } catch (err) {
      console.error(err);
      setError("Unable to load model report.");
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    const timer = window.setTimeout(() => {
      loadReport();
    }, 0);

    return () => window.clearTimeout(timer);
  }, []);

  const retrainModel = async () => {
    setTraining(true);
    setError("");
    try {
      const response = await fetch("/api/model/retrain", { method: "POST" });
      if (!response.ok) {
        throw new Error(`Retrain failed (${response.status})`);
      }
      await response.json();
      await loadReport();
    } catch (err) {
      console.error(err);
      setError("Model training failed. Check Python and dataset files.");
    } finally {
      setTraining(false);
    }
  };

  const matrixLabels = report ? Object.keys(report.confusionMatrix || {}) : [];

  return (
    <div className="page-section">
      <section className="stats-grid">
        <div className="card">
          <div className="stat-card padded">
            <div>
              <p className="muted">Algorithm</p>
              <h3 className="stat-value compact">{report?.algorithm || "Naive Bayes"}</h3>
              <p className="small-muted">Python text classifier</p>
            </div>
            <div className="stat-icon"><Brain size={20} /></div>
          </div>
        </div>
        <div className="card">
          <div className="stat-card padded">
            <div>
              <p className="muted">Accuracy</p>
              <h3 className="stat-value">{loading ? "..." : `${report?.accuracy || 0}%`}</h3>
              <p className="small-muted">Held-out test split</p>
            </div>
            <div className="stat-icon"><WandSparkles size={20} /></div>
          </div>
        </div>
        <div className="card">
          <div className="stat-card padded">
            <div>
              <p className="muted">Dataset</p>
              <h3 className="stat-value">{report?.dataset?.total?.toLocaleString() || "..."}</h3>
              <p className="small-muted">Articles in MySQL</p>
            </div>
            <div className="stat-icon"><Newspaper size={20} /></div>
          </div>
        </div>
        <div className="card">
          <div className="stat-card padded">
            <div>
              <p className="muted">Test Size</p>
              <h3 className="stat-value">{report?.testSize || "..."}</h3>
              <p className="small-muted">Evaluation rows</p>
            </div>
            <div className="stat-icon"><Activity size={20} /></div>
          </div>
        </div>
      </section>

      {error ? <div className="empty-box" style={{ color: "#b91c1c" }}>{error}</div> : null}

      <section className="grid-two">
        <div className="card">
          <div className="card-header row-between">
            <div>
              <h3>Training Control</h3>
              <p>Retrain the Python Multinomial Naive Bayes model from the local dataset.</p>
            </div>
            <button className="btn btn-dark" onClick={retrainModel} disabled={training}>
              <RefreshCcw size={16} />
              {training ? "Training..." : "Retrain"}
            </button>
          </div>
          <div className="card-body explanation">
            <p>
              The training script builds a vocabulary, learns class priors, applies Laplace smoothing,
              evaluates on a held-out test set, and saves the model for live predictions.
            </p>
          </div>
        </div>

        <div className="card">
          <div className="card-header">
            <h3>Dataset Manager</h3>
            <p>Current class balance used by the model.</p>
          </div>
          <div className="card-body stack-gap">
            {(report?.dataset?.byLabel || []).map((item) => (
              <div key={item.label}>
                <div className="progress-label"><span>{item.label}</span><span>{item.count}</span></div>
                <div className="progress">
                  <div className="progress-fill" style={{ width: `${Math.max((item.count / Math.max(report.dataset.total, 1)) * 100, 4)}%` }} />
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <div className="card">
        <div className="card-header">
          <h3>Confusion Matrix</h3>
          <p>Rows are actual labels, columns are predicted labels.</p>
        </div>
        <div className="card-body">
          <div className="table-wrap">
            <table className="custom-table">
              <thead>
                <tr>
                  <th>Actual \ Predicted</th>
                  {matrixLabels.map((label) => <th key={label}>{label}</th>)}
                </tr>
              </thead>
              <tbody>
                {matrixLabels.map((actual) => (
                  <tr key={actual}>
                    <td><strong>{actual}</strong></td>
                    {matrixLabels.map((predicted) => (
                      <td key={predicted}>{report.confusionMatrix?.[actual]?.[predicted] || 0}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  );
}

