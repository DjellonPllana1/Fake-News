function getBadgeClass(label) {
  return classColors[label] || "badge";
}

function filterHistoryRows(rows, query) {
  const normalized = query.trim().toLowerCase();
  if (!normalized) return rows;
  return rows.filter(
    (row) =>
      row.title.toLowerCase().includes(normalized) ||
      row.label.toLowerCase().includes(normalized) ||
      row.source.toLowerCase().includes(normalized)
  );
}

function formatPercent(value) {
  return `${value}%`;
}

const initialPrediction = {
  label: "",
  confidence: 0,
  processed: false,
  explanation: "",
  probabilities: {},
  topEvidence: [],
  modelName: "",
};

function runInlineTests() {
  console.assert(getBadgeClass("Fake").includes("badge-fake"), "Fake badge should use fake styling");
  console.assert(filterHistoryRows(historyRows, "fake").length === 1, "Filter should find the fake row");
  console.assert(filterHistoryRows(historyRows, "city.gov").length === 1, "Filter should match source search");
  console.assert(filterHistoryRows(historyRows, "").length === historyRows.length, "Empty search should return all rows");
  console.assert(filterHistoryRows(historyRows, "SATIRE").length === 1, "Filter should be case insensitive");
  console.assert(formatPercent(97) === "97%", "Percent formatter should append %");
  console.assert(formatPercent(0) === "0%", "Percent formatter should handle zero");
}

function InlineTestRunner() {
  useEffect(() => {
    runInlineTests();
  }, []);
  return null;
}

function LabelBadge({ label }) {
  return <span className={getBadgeClass(label)}>{label}</span>;
}

function CustomTooltip({ active, payload, label, suffix = "" }) {
  if (!active || !payload || !payload.length) return null;

  return (
    <div className="tooltip-box">
      {label ? <p className="tooltip-title">{label}</p> : null}
      {payload.map((entry, index) => (
        <div key={`${entry.name}-${index}`} className="tooltip-row">
          <span>{entry.name}</span>
          <span className="tooltip-value">
            {entry.value}
            {suffix}
          </span>
        </div>
      ))}
    </div>
  );
}

function Sidebar({ activePage, setActivePage, mobileOpen, setMobileOpen, user, onLogout }) {
  return (
    <>
      {mobileOpen && <div className="sidebar-overlay" onClick={() => setMobileOpen(false)} />}
      <aside className={`sidebar ${mobileOpen ? "sidebar-open" : ""}`}>
        <div className="sidebar-header">
          <div>
            <p className="sidebar-label">AI Platform</p>
            <h1 className="sidebar-title">Fake News Detect</h1>
          </div>
          <button className="icon-btn mobile-only" onClick={() => setMobileOpen(false)}>
            <X size={20} />
          </button>
        </div>

        <div className="profile-card">
          <div className="avatar">{user?.name?.split(" ").map((part) => part[0]).join("").slice(0, 2) || "DP"}</div>
          <div>
            <p className="profile-name">{user?.name || "Dion Pllana"}</p>
            <p className="profile-role">{user?.role || "Student / Admin"}</p>
          </div>
        </div>

        <nav className="sidebar-nav">
          {sidebarItems.map((item) => {
            const Icon = item.icon;
            const active = activePage === item.id;
            return (
              <button
                key={item.id}
                className={`nav-item ${active ? "nav-item-active" : ""}`}
                onClick={() => {
                  setActivePage(item.id);
                  setMobileOpen(false);
                }}
              >
                <Icon size={18} />
                <span>{item.label}</span>
              </button>
            );
          })}
        </nav>

        <div className="sidebar-footer">
          <button className="btn btn-danger btn-full" onClick={onLogout}>
            <LogOut size={16} />
            Logout
          </button>
        </div>
      </aside>
    </>
  );
}

