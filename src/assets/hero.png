function LoginPage({ onLogin }) {
  const [email, setEmail] = useState("dion@demo.com");
  const [password, setPassword] = useState("password123");
  const [remember, setRemember] = useState(true);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  const submitLogin = async () => {
    setLoading(true);
    setError("");

    try {
      const response = await fetch("/api/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password }),
      });

      if (!response.ok) throw new Error("Invalid login");
      const data = await response.json();
      onLogin(data.user, data.token, remember);
    } catch (err) {
      console.error(err);
      setError("Email ose password nuk eshte i sakte.");
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="login-page">
      <div className="auth-preview login-panel">
      <div className="auth-left">
        <p className="auth-label">Welcome back</p>
        <h2>Analyze online news with AI-powered confidence.</h2>
        <p className="auth-text">
          Detect fake, satire, bias, and real news from one clean dashboard built for teams, students, and researchers.
        </p>
        <div className="auth-points">
          <div><CheckCircle2 size={16} /> JWT authentication and role-based access</div>
          <div><CheckCircle2 size={16} /> Real-time WebSocket notifications</div>
          <div><CheckCircle2 size={16} /> Reports, exports, and ML integration</div>
        </div>
      </div>

      <div className="auth-right">
        <div className="auth-form">
          <div>
            <h3>Sign in</h3>
            <p>Use demo credentials or a user from MySQL.</p>
          </div>
          <div>
            <label className="field-label">Email</label>
            <input className="input" value={email} onChange={(event) => setEmail(event.target.value)} placeholder="you@example.com" />
          </div>
          <div>
            <label className="field-label">Password</label>
            <input className="input" value={password} onChange={(event) => setPassword(event.target.value)} type="password" placeholder="password" />
          </div>
          {error ? <div className="empty-box" style={{ color: "#b91c1c" }}>{error}</div> : null}
          <div className="remember-row">
            <label><input type="checkbox" checked={remember} onChange={(event) => setRemember(event.target.checked)} /> Remember me</label>
            <button className="link-btn" type="button">Forgot password?</button>
          </div>
          <button className="btn btn-dark btn-full" disabled={loading} onClick={submitLogin} type="button">{loading ? "Signing in..." : "Login"}</button>
          <button className="btn btn-light btn-full" type="button">Create account</button>
        </div>
      </div>
      </div>
    </div>
  );
}

export default function App() {
  const [activePage, setActivePage] = useState("dashboard");
  const [mobileOpen, setMobileOpen] = useState(false);
  const [session, setSession] = useState(() => {
    const saved = window.localStorage.getItem("fake-news-session") || window.sessionStorage.getItem("fake-news-session");
    return saved ? JSON.parse(saved) : null;
  });

  const handleLogin = (user, token, remember) => {
    const nextSession = { user, token };
    setSession(nextSession);
    const storage = remember ? window.localStorage : window.sessionStorage;
    storage.setItem("fake-news-session", JSON.stringify(nextSession));
    if (remember) window.sessionStorage.removeItem("fake-news-session");
    else window.localStorage.removeItem("fake-news-session");
  };

  const handleLogout = () => {
    setSession(null);
    setActivePage("dashboard");
    window.localStorage.removeItem("fake-news-session");
    window.sessionStorage.removeItem("fake-news-session");
  };

  const renderPage = () => {
    switch (activePage) {
      case "dashboard":
        return <DashboardPage />;
      case "analyze":
        return <AnalyzePage />;
      case "mlLab":
        return <MlLabPage />;
      case "history":
        return <HistoryPage />;
      case "reports":
        return <ReportsPage />;
      case "notifications":
        return <NotificationsPage />;
      case "admin":
        return <AdminPage />;
      case "settings":
        return <SettingsPage />;
      default:
        return <DashboardPage />;
    }
  };

  if (!session) {
    return (
      <div className="app-shell">
        <LoginPage onLogin={handleLogin} />
      </div>
    );
  }

  return (
    <div className="app-shell">
      <InlineTestRunner />
      <Sidebar
        activePage={activePage}
        setActivePage={setActivePage}
        mobileOpen={mobileOpen}
        setMobileOpen={setMobileOpen}
        user={session.user}
        onLogout={handleLogout}
      />

      <main className="main-content">
        <Topbar setMobileOpen={setMobileOpen} user={session.user} />
        <div className="content-area">
          {renderPage()}
        </div>
      </main>
    </div>
  );
}
